TELEGRAM_BOT_TOKEN=123456:replace-me
DATABASE_PATH=./bot.db
OSRM_BASE_URL=https://router.project-osrm.org
NOMINATIM_USER_AGENT=warsaw-beer-bot (contact@example.com)
LOG_LEVEL=info
DEFAULT_ROUTE_N=5

# Days of tap-snapshot history to retain (older snapshots are pruned daily;
# each pub always keeps its latest snapshot regardless). Default 14.
SNAPSHOT_RETENTION_DAYS=14

# Untappd lookups master switch (default true) and consecutive-block threshold
# before the circuit breaker trips (default 3).
UNTAPPD_LOOKUP_ENABLED=true
UNTAPPD_BLOCK_THRESHOLD=3
# Optional: rotate+retry attempts on a Cloudflare block before surfacing to the breaker (default 6)
UNTAPPD_BLOCK_RETRIES=6

# Edit the prod .env additively via scripts/set-env.sh — never hand-rewrite the
# whole file (that risks silently dropping a key). The bot WARNs at startup for any
# of the "expected in prod" optional keys below that is unset.

# Optional: value of the untappd_user_v3_e cookie for profile scraping.
# Get it: DevTools → Application → Cookies → untappd.com → untappd_user_v3_e → Value column
# Rotate: ./deploy/refresh-cookie.sh <new-value>
# UNTAPPD_SESSION_COOKIE=

# Optional: Webshare rotating proxy for Untappd traffic (block protection),
# as user:pass@host:port. Unset = direct (risks IP blocks).
# WEBSHARE_PROXY=

# Optional: your Telegram user ID for cookie-expiry DM alerts + daily status digest.
# Find it: send /start to @userinfobot on Telegram.
# ADMIN_TELEGRAM_ID=

# Port for the embedded read-only extension API (bound to 127.0.0.1)
API_PORT=3000

# admin token for POST /admin/* maintenance endpoints; unset = those endpoints return 503
# ADMIN_API_TOKEN=

# --- Orphan-triage job (daily LLM triage of enrich_failures → GitHub issues) ---
# LLM provider + model. Provider: anthropic | openai. Model id is passed verbatim.
TRIAGE_LLM_PROVIDER=anthropic
TRIAGE_LLM_MODEL=claude-opus-4-8
# API key for the chosen provider. Missing key = triage job disabled (digest says so).
# ANTHROPIC_API_KEY=
# OPENAI_API_KEY=
# Repo-scoped token for creating/commenting orphan-triage issues.
# GITHUB_TOKEN=
GITHUB_REPO=ysilvestrov/warsaw-beer-bot
# Optional: directory for the daily triage raw-I/O archive (rotates 30 files).
# Prod: /var/lib/warsaw-beer-bot/triage-logs. Unset = archive disabled.
TRIAGE_LOG_DIR=
